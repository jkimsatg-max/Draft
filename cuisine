            aspect-ratio: 1;
            margin: 0 auto;
            border-radius: 9999px;
            border: 2px solid rgba(255, 255, 255, 0.35);
            background: radial-gradient(circle, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.04) 62%, transparent 100%);
            overflow: hidden;
        }

        .orbit {
            position: absolute;
            inset: 0;
            border-radius: 9999px;
            animation: spin linear infinite;
        }

        .orbit-1 { animation-duration: 18s; }
        .orbit-2 { animation-duration: 24s; animation-direction: reverse; }
        .orbit-3 { animation-duration: 30s; }

        .flag {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: rotate(var(--angle)) translateY(calc(var(--radius) * -1)) rotate(calc(var(--angle) * -1));
